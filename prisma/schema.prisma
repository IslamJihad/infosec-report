generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Report {
  id             String   @id @default(uuid())
  title          String   @default("تقرير أمن المعلومات")
  orgName        String   @default("شركة المستقبل للتقنية")
  subject        String   @default("")
  recipientName  String   @default("")
  period         String   @default("")
  issueDate      String   @default("")
  version        String   @default("1.0")
  author         String   @default("إدارة أمن المعلومات")
  classification String   @default("سري")
  logoBase64     String   @default("")
  summary        String   @default("")
  securityLevel  String   @default("متوسط")
  securityScore  Int      @default(0)
  trend          String   @default("مستقر →")
  status         String   @default("draft")
  chairNote      String   @default("")

  // KPI current
  kpiCritical    Int @default(0)
  kpiVuln        Int @default(0)
  kpiTotal       Int @default(0)
  kpiCompliance  Int @default(0)

  // KPI previous
  prevCritical   Int @default(0)
  prevVuln       Int @default(0)
  prevTotal      Int @default(0)
  prevCompliance Int @default(0)
  kpiComment     String @default("")

  // Vulnerability distribution
  vulnCritical   Int @default(0)
  vulnHigh       Int @default(0)
  vulnMedium     Int @default(0)
  vulnLow        Int @default(0)

  // Incident status
  incOpen        Int @default(0)
  incProgress    Int @default(0)
  incClosed      Int @default(0)
  incWatch       Int @default(0)

  // SLA
  slaMTTC        Float @default(0)
  slaMTTCTarget  Float @default(24)
  slaRate        Float @default(0)
  slaBreach      Int   @default(0)

  // Section toggles
  showSLA        Boolean @default(true)
  showMaturity   Boolean @default(true)

  // ROI & Benchmark
  vulnResolved   Int    @default(0)
  vulnRecurring  Int    @default(0)
  bmScore        Int    @default(0)
  bmCompliance   Int    @default(0)
  bmSector       String @default("")

  // ISO 27001 Controls (JSON array of 14 domains)
  isoControls    String @default("[]")

  // SPS v1 domain data (JSON array of 6 domains with sub-metrics)
  spsDomainsJson String @default("[]")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  decisions       Decision[]
  risks           Risk[]
  maturityDomains MaturityDomain[]
  recommendations Recommendation[]
  assets          Asset[]
  challenges      Challenge[]
  efficiencyKPIs  EfficiencyKPI[]
  aiConversations AIConversation[]
}

model Decision {
  id          String @id @default(uuid())
  reportId    String
  report      Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  title       String @default("")
  description String @default("")
  budget      String @default("")
  department  String @default("")
  timeline    String @default("")
  owner       String @default("")
  sortOrder   Int    @default(0)
}

model Risk {
  id          String @id @default(uuid())
  reportId    String
  report      Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  description  String @default("")
  system       String @default("")
  severity     String @default("medium")
  status       String @default("open")
  probability  Int    @default(3)
  impact       Int    @default(3)
  worstCase    String @default("")
  requiredControls String @default("")
  affectedAssets String @default("")
  sortOrder    Int    @default(0)
}

model MaturityDomain {
  id        String @id @default(uuid())
  reportId  String
  report    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  name      String @default("")
  score     Int    @default(1)
  sortOrder Int    @default(0)
}

model Recommendation {
  id          String @id @default(uuid())
  reportId    String
  report      Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  title       String @default("")
  description String @default("")
  priority    String @default("medium")
  department  String @default("")
  timeline    String @default("")
  owner       String @default("")
  sortOrder   Int    @default(0)
}

model EfficiencyKPI {
  id          String  @id @default(uuid())
  reportId    String
  report      Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  title       String  @default("")
  val         Float   @default(0)
  target      Float   @default(100)
  unit        String  @default("%")
  description String  @default("")
  lowerBetter Boolean @default(false)
  sortOrder   Int     @default(0)
}

model AIConversation {
  id         String @id @default(uuid())
  reportId   String
  report     Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reviewType String @default("full")
  title      String?
  pinned     Boolean @default(false)
  messages   String @default("[]")
  createdAt  DateTime @default(now())
}

model Asset {
  id              String @id @default(uuid())
  reportId        String
  report          Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  name            String @default("")
  value           String @default("")
  protectionLevel Int    @default(50)
  gaps            String @default("")
  sortOrder       Int    @default(0)
}

model Challenge {
  id          String @id @default(uuid())
  reportId    String
  report      Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  title       String @default("")
  type        String @default("budget")
  rootCause   String @default("")
  requirement String @default("")
  sortOrder   Int    @default(0)
}

model AppSettings {
  id              String @id @default("singleton")
  aiApiKey        String @default("") // legacy fallback for older deployments
  aiProvider      String @default("gemini")
  geminiApiKey    String @default("")
  nvidiaApiKey    String @default("")
  aiModel         String @default("gemini-2.5-flash")
  defaultOrgName  String @default("")
  defaultAuthor   String @default("")
}

model IsmsWorkspace {
  id            String   @id @default("default")
  orgName       String   @default("")
  cisoName      String   @default("")
  scope         String   @default("")
  certBody      String   @default("")
  targetDate    String   @default("")
  industry      String   @default("")
  employeeCount String   @default("")

  clauseStatus  String   @default("{}")
  controlStatus String   @default("{}")
  soaData       String   @default("{}")
  docStatus     String   @default("{}")
  dailyChecks   String   @default("{}")
  dailyNotes    String   @default("{}")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  risks         IsmsRisk[]
  assets        IsmsAsset[]
  incidents     IsmsIncident[]
  tasks         IsmsTask[]
  team          IsmsTeamMember[]
  kpis          IsmsKpi[]
  suppliers     IsmsSupplier[]
  awareness     IsmsAwareness[]
  audits        IsmsAudit[]
  ncas          IsmsNca[]
}

model IsmsRisk {
  id          String        @id @default(uuid())
  workspaceId String        @default("default")
  workspace   IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String        @default("")
  category    String        @default("")
  asset       String        @default("")
  likelihood  Int           @default(1)
  impact      Int           @default(1)
  treatment   String        @default("Mitigate")
  treatDesc   String        @default("")
  owner       String        @default("")
  targetDate  String        @default("")
  status      String        @default("Open")
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
}

model IsmsAsset {
  id             String        @id @default(uuid())
  workspaceId    String        @default("default")
  workspace      IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String        @default("")
  type           String        @default("Information")
  classification String        @default("Internal")
  criticality    String        @default("Medium")
  owner          String        @default("")
  location       String        @default("")
  description    String        @default("")
  sortOrder      Int           @default(0)
}

model IsmsIncident {
  id          String        @id @default(uuid())
  workspaceId String        @default("default")
  workspace   IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String        @default("")
  detectedAt  String        @default("")
  severity    String        @default("Medium")
  category    String        @default("Other")
  description String        @default("")
  impact      String        @default("")
  actions     String        @default("")
  lessons     String        @default("")
  status      String        @default("Open")
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
}

model IsmsTask {
  id          String        @id @default(uuid())
  workspaceId String        @default("default")
  workspace   IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String        @default("")
  description String        @default("")
  assignee    String        @default("")
  priority    String        @default("Medium")
  domain      String        @default("General")
  dueDate     String        @default("")
  status      String        @default("todo")
  notes       String        @default("")
  sortOrder   Int           @default(0)
}

model IsmsTeamMember {
  id          String        @id @default(uuid())
  workspaceId String        @default("default")
  workspace   IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String        @default("")
  role        String        @default("")
  department  String        @default("")
}

model IsmsKpi {
  id          String        @id @default(uuid())
  workspaceId String        @default("default")
  workspace   IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String        @default("")
  category    String        @default("")
  unit        String        @default("%")
  target      Float         @default(100)
  current     Float         @default(0)
  frequency   String        @default("Monthly")
  trend       String        @default("flat")
  sortOrder   Int           @default(0)
}

model IsmsSupplier {
  id            String        @id @default(uuid())
  workspaceId   String        @default("default")
  workspace     IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String        @default("")
  category      String        @default("")
  riskLevel     String        @default("Medium")
  dataAccess    String        @default("")
  service       String        @default("")
  contractExp   String        @default("")
  nextReview    String        @default("")
  assessment    String        @default("Not Started")
  notes         String        @default("")
  sortOrder     Int           @default(0)
}

model IsmsAwareness {
  id             String        @id @default(uuid())
  workspaceId    String        @default("default")
  workspace      IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title          String        @default("")
  type           String        @default("Online Training")
  sessionDate    String        @default("")
  audience       String        @default("")
  completionRate Float         @default(0)
  status         String        @default("Completed")
  notes          String        @default("")
  sortOrder      Int           @default(0)
}

model IsmsAudit {
  id          String        @id @default(uuid())
  workspaceId String        @default("default")
  workspace   IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String        @default("")
  scope       String        @default("")
  auditDate   String        @default("")
  auditor     String        @default("")
  clauses     String        @default("")
  auditType   String        @default("Internal")
  status      String        @default("Planned")
  findings    String        @default("")
  sortOrder   Int           @default(0)
}

model IsmsNca {
  id               String        @id @default(uuid())
  workspaceId      String        @default("default")
  workspace        IsmsWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reference        String        @default("")
  type             String        @default("NC")
  description      String        @default("")
  rootCause        String        @default("")
  correctiveAction String        @default("")
  owner            String        @default("")
  dueDate          String        @default("")
  status           String        @default("Open")
  sortOrder        Int           @default(0)
}
