{
  "name": "infosec-report",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:push:force": "prisma db push --accept-data-loss",
    "prisma:studio": "prisma studio",
    "isms:generate:constants": "node scripts/generate-isms-constants.mjs",
    "isms:generate:routes": "node scripts/generate-isms-routes.mjs",
    "isms:generate": "npm run isms:generate:constants && npm run isms:generate:routes",
    "isms:generate:if-source": "node scripts/run-isms-generate-if-source.mjs",
    "dev:setup": "npm run prisma:generate && npm run isms:generate:if-source",
    "dev:bootstrap": "npm run dev:setup && npm run dev",
    "verify:prisma": "prisma validate",
    "verify:typecheck": "tsc --noEmit",
    "verify:lint": "eslint .",
    "verify:all": "npm run verify:prisma && npm run verify:typecheck && npm run verify:lint && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.0",
    "next": "16.1.6",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
